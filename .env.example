# IMS Agent — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# --- Anthropic API ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- File Paths ---
# Path to the IMS XML file (MSPDI format)
IMS_FILE_PATH=data/sample_ims.xml
# Directory where generated reports are saved
REPORTS_DIR=reports
# Directory where logs are written
LOGS_DIR=logs

# --- Schedule Settings ---
# Reporting period end date (YYYY-MM-DD). Defaults to today if not set.
REPORTING_PERIOD_END=

# --- SRA Settings ---
# Number of Monte Carlo iterations
SRA_ITERATIONS=1000
# Default duration uncertainty as a fraction (±10% = 0.10)
SRA_DURATION_UNCERTAINTY=0.10
# Risk thresholds (probability of hitting baseline)
SRA_HIGH_RISK_THRESHOLD=0.50
SRA_MEDIUM_RISK_THRESHOLD=0.75

# --- Critical Path Settings ---
# Tasks with float <= this many days are flagged as near-critical
NEAR_CRITICAL_FLOAT_DAYS=5

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# PHASE 2 — VOICE INTERVIEW LAYER
# =============================================================================

# --- Call Transport ---
# Options: simulated (default, no infra needed) | teams_acs (production)
CALL_TRANSPORT=simulated

# --- ElevenLabs TTS ---
# Get your key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Voice ID — defaults to "Rachel" (professional female). Find IDs at elevenlabs.io/voice-lab
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Model: eleven_turbo_v2 (fast, good quality) | eleven_multilingual_v2 (best quality)
ELEVENLABS_MODEL=eleven_turbo_v2

# --- Azure Neural TTS (Phase 5 — replaces ElevenLabs for on-prem/ITAR) ---
# TTS_PROVIDER=azure   (set to "azure" to activate; default is "elevenlabs")
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_TTS_VOICE=en-US-BrianMultilingualNeural

# --- STT (Whisper — local, no API key needed) ---
# Model size: tiny | base | small | medium | large  (larger = slower + more accurate)
# In simulation mode this is bypassed entirely.
WHISPER_MODEL=base
# Optional: inject domain vocabulary as context for better accuracy
WHISPER_INITIAL_PROMPT=IMS schedule status, percent complete, critical path, PDR, CDR, TRR, CAM, milestone

# --- Azure ACS / Teams (production transport — requires Azure subscription) ---
# See docs/teams-integration-decision.md for setup instructions
ACS_CONNECTION_STRING=
ACS_PHONE_NUMBER=
TEAMS_AGENT_USER_ID=
TEAMS_TENANT_ID=

# --- Interview Settings ---
# Seconds to wait for a response before re-prompting
INTERVIEW_RESPONSE_TIMEOUT_SEC=15
# Max re-prompts before marking task as no-response
INTERVIEW_MAX_RETRIES=3
# Max concurrent CAM calls (simulated mode supports any number)
INTERVIEW_MAX_CONCURRENT=5

# --- CAM Directory ---
# JSON file defining CAMs, Teams IDs, emails, timezones
CAM_DIRECTORY_PATH=data/cam_directory.json

# =============================================================================
# PHASE 3 — FULL AUTOMATION LOOP
# =============================================================================

# --- Scheduler ---
# Cron expression for recurring cycles (default: Monday at 06:00)
SCHEDULE_CRON=0 6 * * 1
# IANA timezone for the cron trigger
SCHEDULE_TIMEZONE=America/New_York
# Minimum fraction of CAMs that must respond before proceeding (0.0–1.0)
INTERVIEW_COMPLETION_THRESHOLD=0.80

# --- Validation ---
# Maximum percent increase allowed in one cycle before flagging as warning
VALIDATION_MAX_JUMP_PCT=50
# Allow percent_complete to decrease (default: false — flag as failure)
VALIDATION_ALLOW_BACKWARDS=false

# --- Dashboard ---
# Port for the FastAPI dashboard server
DASHBOARD_PORT=8080
# Public URL of the dashboard (used in Slack/email links)
DASHBOARD_URL=http://localhost:8080
# Path to the live dashboard state file (written after each cycle)
DASHBOARD_STATE_FILE=data/dashboard_state.json
# Path to the rolling cycle history file
CYCLE_HISTORY_FILE=data/cycle_history.json

# --- Voice Briefing (optional) ---
# Set to "true" to generate a 60-90s MP3 briefing for the PM after each cycle
# Requires ELEVENLABS_API_KEY to be set. Output saved to reports/briefings/
VOICE_BRIEFING_ENABLED=false

# --- Slack ---
# Incoming webhook URL for cycle summary posts
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Bot User OAuth Token (xoxb-...) — required for Phase 4 slash command
SLACK_BOT_TOKEN=
# App-Level Token (xapp-...) — required for Socket Mode (slash command transport)
SLACK_APP_TOKEN=

# --- Email (SMTP) ---
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
# From address shown in cycle summary emails
EMAIL_FROM=
# Comma-separated list of recipient addresses
EMAIL_TO=
